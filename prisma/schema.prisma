generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  email        String   @unique
  password     String
  role         Role     @default(PATIENT)
  phoneNumber  String?
  profileImage String?
  isActive     Boolean  @default(true)
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  doctorProfile DoctorProfile?

  patientAppointments Appointment[] @relation("PatientAppointments")

  @@index([role])
  @@index([isActive])
}

model DoctorProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  specialtyId      String
  bio              String?
  experienceYears  Int      @default(0)
  consultationFee  Int?
  clinicAddress    String?
  rating           Float    @default(0)
  deletedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user       User      @relation(fields: [userId], references: [id])
  specialty  Specialty @relation(fields: [specialtyId], references: [id])
  slots      AvailabilitySlot[]
  doctorAppointments Appointment[] @relation("DoctorAppointments")

  @@index([specialtyId])
}

model Specialty {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  doctorProfiles DoctorProfile[]
}

model AvailabilitySlot {
  id        String   @id @default(cuid())
  doctorId  String
  startTime DateTime
  endTime   DateTime
  isBooked  Boolean  @default(false)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor      DoctorProfile @relation(fields: [doctorId], references: [id])
  appointment Appointment?

  @@unique([doctorId, startTime, endTime])
  @@index([doctorId, startTime])
}

model Appointment {
  id                 String            @id @default(cuid())
  patientId          String
  doctorId           String
  slotId             String            @unique
  status             AppointmentStatus @default(PENDING)
  appointmentDate    DateTime
  notes              String?
  cancellationReason String?
  deletedAt          DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  patient User @relation("PatientAppointments", fields: [patientId], references: [id])
  doctor  DoctorProfile @relation("DoctorAppointments", fields: [doctorId], references: [id])
  slot    AvailabilitySlot @relation(fields: [slotId], references: [id])

  @@index([patientId, appointmentDate])
  @@index([doctorId, appointmentDate])
  @@index([status])
}
